{
  "permissions": {
    "allow": [
      "Bash(php -l *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" --max-time 3 http://localhost:3000/)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(.venv/Scripts/python.exe -m pytest -q)"
    ],
    "deny": [
      "Read(backend/.env)",
      "Grep(backend/.env)",
      "Bash(cat backend/.env)",
      "Bash(head backend/.env)",
      "Bash(tail backend/.env)",
      "Bash(less backend/.env)",
      "Bash(more backend/.env)",
      "Bash(strings backend/.env)",
      "Read(frontend/.env)",
      "Grep(frontend/.env)",
      "Bash(cat frontend/.env)",
      "Bash(head frontend/.env)",
      "Bash(tail frontend/.env)",
      "Bash(less frontend/.env)",
      "Bash(more frontend/.env)",
      "Bash(strings frontend/.env)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "backend/.env",
        "frontend/.env"
      ]
    }
  }
}
